/**
 * 纸娃娃 (Paper Doll) 风格装备与防御面板 - 备份
 * 三层穿戴：内袍 (L1)、身体盔甲 (L2)、外袍 (L3) + 盾牌
 * 实时计算并展示 AC，不包含攻击动作按钮；同调在后台生效
 */
import { getItemById, getItemDisplayName } from '../data/itemDatabase'
import { getAC } from '../lib/formulas'
import {
  DEFENSE_LAYER_IDS,
  DEFENSE_LAYER_LABELS,
  getInventoryForLayer,
  useLayersForAC,
} from '../lib/equipmentLayers'

function layerDisplayName(entry, proto) {
  if (!entry) return '—'
  const customName = entry.name?.trim()
  if (customName) return customName
  return getItemDisplayName(proto) || '—'
}

export default function PaperDoll({ character, canEdit, onSave }) {
  if (!character) return null
  const eq = character.equipment ?? {}
  const inv = character.inventory ?? []
  const setEquip = (patch) => onSave({ equipment: { ...eq, ...patch } })

  let ac
  try {
    ac = getAC(character)
  } catch (e) {
    console.error('PaperDoll getAC:', e)
    ac = { total: 10, base: 10, dexContrib: 0, shield: 0, other: 0, buff: 0 }
  }
  const useLayers = useLayersForAC(eq)

  const getSlot = (layerId) => {
    const raw = eq[layerId]
    return {
      inventoryId: raw?.inventoryId ?? '',
      magicACBonus: Number(raw?.magicACBonus) || 0,
    }
  }

  const getSlotEntry = (layerId) => {
    const slot = getSlot(layerId)
    if (!slot.inventoryId) return null
    return inv.find((e) => e.id === slot.inventoryId) ?? null
  }

  const onLayerSelect = (layerId, inventoryId) => {
    const next = { ...getSlot(layerId), inventoryId: inventoryId || '' }
    if (!inventoryId) next.magicACBonus = 0
    setEquip({ [layerId]: next })
  }

  const setOuterMagicBonus = (value) => {
    const outer = getSlot('outerRobe')
    setEquip({ outerRobe: { ...outer, magicACBonus: value } })
  }

  return (
    <div className="rounded-xl border border-gray-600 bg-dnd-card overflow-hidden">
      <div className="px-4 py-3 border-b border-gray-600 bg-gray-800/60">
        <h3 className="text-white font-bold text-lg">🛡️ 装备与防御</h3>
        <p className="text-dnd-text-muted text-xs mt-1">从背包选择内袍 / 身体盔甲 / 外袍 / 盾牌，AC 自动计算</p>
        <p className="text-amber-200/90 text-xs mt-1">若下拉为空，请先在下方「物品栏」用类型下拉选好盔甲或衣服并放入背包，再回到此处选择装备。</p>
      </div>

      <div className="p-4 flex flex-col md:flex-row gap-6">
        {/* 左侧：纸娃娃槽位 */}
        <div className="flex-1 min-w-0">
          <div className="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {DEFENSE_LAYER_IDS.map((layerId) => {
              const slot = getSlot(layerId)
              const entry = getSlotEntry(layerId)
              const proto = entry?.itemId ? getItemById(entry.itemId) : null
              const options = getInventoryForLayer(inv, layerId)
              const label = DEFENSE_LAYER_LABELS[layerId]

              return (
                <div
                  key={layerId}
                  className="rounded-lg border border-gray-600 bg-gray-800/80 p-3"
                >
                  <div className="text-dnd-gold-light uppercase tracking-wider text-xs font-bold mb-2">
                    {label}
                  </div>
                  {canEdit ? (
                    <>
                      <select
                        value={slot.inventoryId}
                        onChange={(e) => onLayerSelect(layerId, e.target.value)}
                        className="w-full h-10 rounded-lg bg-gray-700 border border-gray-600 text-white text-sm px-3 focus:border-dnd-red focus:ring-1 focus:ring-dnd-red"
                        style={{ color: '#fff' }}
                      >
                        <option value="">— 从背包选择 —</option>
                        {options.map((e) => {
                          const p = getItemById(e.itemId)
                          const name = layerDisplayName(e, p)
                          return (
                            <option key={e.id} value={e.id}>
                              {name}
                            </option>
                          )
                        })}
                      </select>
                      {options.length === 0 && (
                        <p className="text-amber-200/80 text-xs mt-1.5">
                          {layerId === 'innerRobe' && '背包中暂无【衣服】。在物品栏选类型「衣服」并放入背包后可选。'}
                          {layerId === 'bodyArmor' && '背包中暂无【盔甲】（轻/中/重甲）。在物品栏选类型「盔甲」并放入背包后可选。'}
                          {layerId === 'outerRobe' && '背包中暂无【衣服】或【饰品】。在物品栏添加后可选。'}
                          {layerId === 'shield' && '背包中暂无【盾牌】。在物品栏选类型「盔甲」、子类型「盾牌」并放入背包后可选。'}
                        </p>
                      )}
                    </>
                  ) : (
                    <p className="text-white text-sm py-1.5">{layerDisplayName(entry, proto)}</p>
                  )}
                  {layerId === 'outerRobe' && canEdit && (slot.inventoryId || slot.magicACBonus) && (
                    <div className="mt-2 flex items-center gap-2">
                      <span className="text-dnd-text-muted text-xs">AC 加值</span>
                      <input
                        type="number"
                        min={0}
                        value={slot.magicACBonus || ''}
                        onChange={(e) => setOuterMagicBonus(parseInt(e.target.value, 10) || 0)}
                        placeholder="0"
                        className="w-14 h-8 rounded bg-gray-700 border border-gray-600 text-white text-right text-sm px-2"
                      />
                    </div>
                  )}
                </div>
              )
            })}
          </div>

          {/* 其他 AC 加成（戒指、护符等） */}
          <div className="mt-3 rounded-lg border border-gray-600 bg-gray-800/60 p-3">
            <label className="text-dnd-text-muted text-xs font-bold uppercase tracking-wider block mb-2">
              其他 AC 加成（附魔、戒指、护符等）
            </label>
            {canEdit ? (
              <input
                type="number"
                min={0}
                value={eq.otherAC ?? ''}
                onChange={(e) => setEquip({ otherAC: e.target.value === '' ? '' : parseInt(e.target.value, 10) || 0 })}
                placeholder="0"
                className="h-10 w-20 rounded-lg bg-gray-800 border border-gray-600 text-white text-center px-2 focus:border-dnd-red focus:ring-1 focus:ring-dnd-red"
              />
            ) : (
              <span className="text-white font-mono">{(eq.otherAC && eq.otherAC !== 0) ? `+${eq.otherAC}` : '—'}</span>
            )}
          </div>
        </div>

        {/* 右侧：AC 展示 */}
        <div className="md:w-48 shrink-0 flex flex-col items-center justify-center rounded-xl border border-amber-600/40 bg-amber-950/30 p-6">
          <span className="text-dnd-gold-light text-xs font-bold uppercase tracking-wider">防御等级</span>
          <span className="text-4xl font-bold font-mono text-white tabular-nums mt-1">{ac.total}</span>
          <div className="text-dnd-text-muted text-xs mt-3 text-center space-y-0.5">
            {useLayers ? (
              <>
                {ac.base != null && <p>基础 {ac.base}</p>}
                {ac.dexContrib != null && ac.dexContrib !== 0 && <p>敏捷 {ac.dexContrib >= 0 ? '+' : ''}{ac.dexContrib}</p>}
                {ac.outerMagic != null && ac.outerMagic > 0 && <p>外袍 +{ac.outerMagic}</p>}
                {ac.shield != null && ac.shield > 0 && <p>盾牌 +{ac.shield}</p>}
                {ac.other != null && ac.other !== 0 && <p>其他 {ac.other >= 0 ? '+' : ''}{ac.other}</p>}
                {ac.buff != null && ac.buff !== 0 && <p>增益 {ac.buff >= 0 ? '+' : ''}{ac.buff}</p>}
              </>
            ) : (
              <>
                <p>基础 {ac.base}</p>
                <p>敏捷 {ac.dexContrib >= 0 ? '+' : ''}{ac.dexContrib}</p>
                {ac.shield > 0 && <p>盾牌 +{ac.shield}</p>}
                {ac.other !== 0 && <p>其他 {ac.other >= 0 ? '+' : ''}{ac.other}</p>}
                {ac.buff !== 0 && <p>增益 {ac.buff >= 0 ? '+' : ''}{ac.buff}</p>}
              </>
            )}
          </div>
        </div>
      </div>
    </div>
  )
}
